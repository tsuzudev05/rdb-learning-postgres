{
  "name": "rdb-learning-postgres",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",

  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },

  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=/root/.ssh,type=bind,consistency=cached"
  ],

  "remoteEnv": {
    "GIT_AUTHOR_NAME": "${localEnv:GIT_AUTHOR_NAME}",
    "GIT_AUTHOR_EMAIL": "${localEnv:GIT_AUTHOR_EMAIL}",
    "GIT_COMMITTER_NAME": "${localEnv:GIT_COMMITTER_NAME}",
    "GIT_COMMITTER_EMAIL": "${localEnv:GIT_COMMITTER_EMAIL}"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg",
        "ms-azuretools.vscode-docker",
        "anthropic.claude-code",
        "GitHub.copilot",
        "streetsidesoftware.code-spell-checker-japanese",
        "yzhang.markdown-all-in-one",
        "hediet.vscode-drawio"
      ],
      "settings": {
        "sqltools.connections": [
          {
            "name": "PostgreSQL (pg-dev)",
            "driver": "PostgreSQL",
            "host": "postgres",
            "port": 5432,
            "database": "learning",
            "username": "postgres",
            "password": "pass"
          }
        ],
        "terminal.integrated.defaultProfile.linux": "bash",
        "editor.formatOnSave": true,
        "editor.tabSize": 2
      }
    }
  },

  "postCreateCommand": "bash .devcontainer/setup.sh"
}
