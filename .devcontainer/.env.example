# ─────────────────────────────────────────────────────────
# PostgreSQL 接続情報（docker-compose.yml と合わせること）
# ─────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=learning
POSTGRES_USER=postgres
POSTGRES_PASSWORD=pass
DATABASE_URL=postgresql://postgres:pass@postgres:5432/learning
